# These values are embedded in public HTML at build time. Do not put secrets here.
PUBLIC_ANALYTICS_PROVIDER=plausible
PUBLIC_ANALYTICS_DOMAIN=russelleast.github.io
# Optional; omit to use Plausible's standard script URL.
PUBLIC_ANALYTICS_SCRIPT_URL=https://plausible.io/js/script.js

# Optional Google Search Console HTML-tag verification value.
PUBLIC_GOOGLE_SITE_VERIFICATION=
