---
interface Item {
  label: string;
  value: string | number | undefined | null;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
const visible = items.filter((item) => item.value !== undefined && item.value !== null && item.value !== "");
---

<dl class="metadata-list">
  {visible.map((item) => (
    <>
      <dt>{item.label}</dt>
      <dd>{item.value}</dd>
    </>
  ))}
</dl>
