---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Analytics from "@/components/Analytics.astro";
import Seo from "@/components/Seo.astro";
import { siteDescription, withBase } from "@/utils/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  type?: "website" | "article";
  image?: string;
  author?: string;
  article?: {
    published: Date;
    updated?: Date;
    tags?: string[];
  };
  analytics?: {
    contentType: "page" | "episode";
    episode?: string;
    series?: string;
  };
}

const { analytics = { contentType: "page" }, ...seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo {...seo} description={seo.description ?? siteDescription} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <Analytics
      contentType={analytics.contentType}
      episode={analytics.episode}
      series={analytics.series}
    />
  </head>
  <body
    data-content-type={analytics.contentType}
    data-episode={analytics.episode}
    data-series={analytics.series}
  >
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
