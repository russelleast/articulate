# Shared Articulate diagram primitives. Individual diagrams may override any style.
classes: {
  node: {
    shape: rectangle
    style: {
      fill: "#F7F4ED"
      stroke: "#263746"
      stroke-width: 2
      border-radius: 8
      font-color: "#17232D"
      font-size: 22
    }
  }
  emphasis: {
    shape: rectangle
    style: {
      fill: "#DCEBE7"
      stroke: "#176B62"
      stroke-width: 3
      border-radius: 8
      font-color: "#103D39"
      font-size: 24
      bold: true
    }
  }
  capability: {
    shape: rectangle
    style: {
      fill: "#E8EDF2"
      stroke: "#49677C"
      stroke-width: 2
      border-radius: 8
      font-color: "#17232D"
      font-size: 20
    }
  }
  evidence: {
    shape: rectangle
    style: {
      fill: "#F2E8D8"
      stroke: "#8A6235"
      stroke-width: 2
      border-radius: 8
      font-color: "#49321E"
      font-size: 21
    }
  }
}
