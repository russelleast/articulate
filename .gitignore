## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# Articulate website
site/node_modules/
site/dist/
site/.astro/
site/.playwright-cli/

# Companion PoC generated media
production/experiments/companion-poc-001/runtime/output/*
!production/experiments/companion-poc-001/runtime/output/.gitkeep
production/experiments/companion-poc-001/generated/scenes/*
!production/experiments/companion-poc-001/generated/scenes/.gitkeep
production/experiments/companion-poc-001/generated/subtitles/*
!production/experiments/companion-poc-001/generated/subtitles/.gitkeep
production/experiments/companion-poc-001/generated/manifests/*
!production/experiments/companion-poc-001/generated/manifests/.gitkeep
production/experiments/companion-poc-001/inputs/audio/*
!production/experiments/companion-poc-001/inputs/audio/.gitkeep
production/experiments/companion-poc-001/inputs/companion/*
!production/experiments/companion-poc-001/inputs/companion/.gitkeep
production/experiments/companion-poc-001/inputs/visuals/*
!production/experiments/companion-poc-001/inputs/visuals/.gitkeep

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
